{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "g++.exe build active file",
			"type": "shell",
			"command": "/usr/bin/g++",
			"args": [
				"-std=c++11",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}/${fileBasenameNoExtension}"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}